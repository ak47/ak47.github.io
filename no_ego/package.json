    "gatsby-source-filesystem": "^5.14.0",
    "gatsby-transformer-remark": "^6.14.0",
    "graphql": "^16.9.0",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-typography": "^0.16.19",
    "typography": "^0.16.19",
    "gh-pages": "^6.2.1"
