{
  "name": "gatsby-starter-hello-world",
  "private": true,
  "description": "nO EgO site (Gatsby 5)",
  "version": "0.1.0",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "gatsby build",
    "develop": "gatsby develop",
    "format": "prettier --write \"**/*.{js,jsx,json,md}\"",
    "start": "npm run develop",
    "serve": "gatsby serve",
    "clean": "gatsby clean",
    "test": "jest",
    "deploy": "gatsby build && gh-pages -d public -b main"
  },
  "dependencies": {
    "@emotion/react": "^11.13.3",
    "@emotion/styled": "^11.13.0",
    "gatsby": "^5.14.1",
    "gatsby-plugin-emotion": "^8.14.0",
    "gatsby-plugin-manifest": "^5.14.0",
    "gatsby-plugin-offline": "^6.14.0",
    "gatsby-plugin-typography": "^5.14.0",
    "gatsby-source-filesystem": "^5.14.0",
    "gatsby-transformer-remark": "^6.14.0",
    "gh-pages": "^6.2.1",
    "graphql": "^17.0.1",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-typography": "^0.16.19",
    "typography": "^0.16.19"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/preset-env": "^8.0.2",
    "babel-jest": "^30.0.5",
    "jest": "^30.0.5",
    "prettier": "^3.9.4"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.jsx?$": "babel-jest"
    },
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/.cache/",
      "/public/"
    ]
  },
  "resolutions": {
    "@parcel/reporter-dev-server": "2.16.4",
    "cookie": "0.7.2",
    "file-type": "21.3.2",
    "immutable": "3.8.3",
    "lodash": "4.18.1",
    "path-to-regexp": "0.1.13",
    "qs": "6.15.2",
    "serialize-javascript": "7.0.5",
    "tmp": "0.2.6",
    "uuid": "11.1.1",
    "webpack": "5.104.1",
    "ws": "8.21.0",
    "@babel/core": "^8.0.1"
  }
}
